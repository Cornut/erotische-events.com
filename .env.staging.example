# ───────────────────────────────────────────────────────────────────────────
# Staging environment template — copy to `.env` on the staging host and fill in.
# After editing, run:  php artisan key:generate   (sets APP_KEY)
# ───────────────────────────────────────────────────────────────────────────

APP_NAME="erotische-events.com"
APP_ENV=staging
APP_KEY=
APP_DEBUG=false
APP_URL=https://staging.erotische-events.com

APP_LOCALE=de
APP_FALLBACK_LOCALE=de
APP_FAKER_LOCALE=de_DE

# Admin account created by AdminUserSeeder (run db:seed BEFORE config:cache).
ADMIN_EMAIL=admin@erotische-events.com
ADMIN_NAME=Admin
ADMIN_PASSWORD=change-me-on-staging

LOG_CHANNEL=stack
LOG_LEVEL=warning

# Database
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=erotic_staging
DB_USERNAME=erotic
DB_PASSWORD=change-me

# Sessions / cache / queue — queue MUST have a running worker (see deploy doc).
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
CACHE_STORE=database
QUEUE_CONNECTION=database

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Full-text search — Meilisearch must be reachable; use a real master key.
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=change-me-strong-master-key

# Mail — REQUIRED for the contact form to actually send (not just log).
MAIL_MAILER=smtp
MAIL_HOST=smtp.your-provider.tld
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SCHEME=tls
MAIL_FROM_ADDRESS="noreply@erotische-events.com"
MAIL_FROM_NAME="${APP_NAME}"

# Scraper / LLM (optional). Without a key the scraper stays AI-free (JSON-LD + iCal).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
SCRAPING_TIMEOUT=15

FILESYSTEM_DISK=public
VITE_APP_NAME="${APP_NAME}"
